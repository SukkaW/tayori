{
  "name": "tayori-monorepo",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SukkaW/tayori.git"
  },
  "scripts": {
    "build": "pnpm --filter tayori build",
    "lint": "eslint --format=sukka .",
    "example:dev": "pnpm --filter example-nextjs-app dev",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "prerelease": "pnpm run lint && pnpm run build",
    "release": "bumpp packages/tayori/package.json --install -r --commit \"release: %s\" --tag \"%s\""
  },
  "devDependencies": {
    "@eslint-sukka/react": "^8.12.2",
    "bumpp": "^10.4.1",
    "eslint": "^10.5.0",
    "eslint-config-sukka": "^8.12.2",
    "eslint-formatter-sukka": "^8.12.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.8.0"
}
