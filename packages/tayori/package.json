{
  "name": "tayori",
  "version": "0.3.8",
  "description": "An opinionated React client-side data fetching stack built with Ky, SWR, Zod and Hey API",
  "repository": {
    "type": "git",
    "url": "https://github.com/SukkaW/tayori",
    "directory": "packages/tayori"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bunchee --minify --no-sourcemap",
    "lint": "eslint --format=sukka ."
  },
  "keywords": [
    "SWR",
    "Hey API",
    "React",
    "OpenAPI",
    "TypeScript"
  ],
  "author": "Sukka <https://skk.moe>",
  "license": "MIT",
  "dependencies": {
    "foxact": "^0.3.8",
    "stable-hash": "^0.0.6"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/react": "^19.2.17",
    "bunchee": "^6.11.0",
    "react": "^19.2.7",
    "swr": "^2.4.2",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "swr": "^2.4.0"
  }
}
